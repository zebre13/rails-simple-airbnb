<div class="container">

  <div class="py-3">
    <h1>All our Flats (<%= @flats.length %>)</h1>
  </div>

  <div class="d-flex justify-content-between">
    <% @flats.each do |flat| %>
      <div class="p-1 m-1">
        <div>
          <h5>
            <%= flat.name %>
          </h5>
          <%= flat.address %>
          <div class="d-flex">
            <%= flat.number_of_guests %>
            <%= flat.price_per_night %>
          </div>
        </div>
        <%= link_to 'More info', flat_path(flat) %>
      </div>
    <% end %>
  </div>

</div>
