<div class="container">

  <div class="py-3">
    <h1>All our Flats (<%= @flats.length %>)</h1>
  </div>

  <div class="d-flex justify-content-between">
    <% @flats.each do |flat| %>
      <div class="m-3 border">
        <div class="text-center">
          <<< Image >>>
        </div>
        <div class="border-bottom p-3">
          <h5>
            <%= flat.name %>
          </h5>
          <%= flat.address %>
          <div class="d-flex">
            <%= flat.number_of_guests %>
            <%= flat.price_per_night %>
          </div>
        </div>
        <div class="d-flex p-3">
          <div class="pe-3">
            <%= link_to 'More info', flat_path(flat) %>
          </div>
          <div class="pe-3">
            <%= link_to 'Edit', edit_flat_path(flat) %>
          </div>
          <div class="pe-3">
            <%= link_to 'Remove', flat_path(flat), method: :delete, data: { confirm: "Are you sure?" } %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

</div>
